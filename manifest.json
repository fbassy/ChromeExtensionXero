{
  "manifest_version": 3,
  "name": "Xero for Gmail",
  "version": "1.0.0",
  "description": "View Xero financial data for email contacts directly in Gmail",
  "permissions": ["sidePanel", "identity", "storage", "tabs", "alarms"],
  "host_permissions": [
    "https://mail.google.com/*",
    "https://api.xero.com/*",
    "https://login.xero.com/*",
    "https://identity.xero.com/*",
    "https://www.googleapis.com/*",
    "https://www.google-analytics.com/*"
  ],
  "oauth2": {
    "client_id": "__GOOGLE_OAUTH_CLIENT_ID__",
    "scopes": ["https://www.googleapis.com/auth/gmail.readonly"]
  },
  "background": { "service_worker": "background.js" },
  "side_panel": { "default_path": "sidepanel.html" },
  "content_scripts": [
    { "matches": ["https://mail.google.com/*"], "js": ["gmail-detector.js"], "run_at": "document_idle" }
  ],
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" },
  "content_security_policy": { "extension_pages": "script-src 'self'; object-src 'none'" }
}
