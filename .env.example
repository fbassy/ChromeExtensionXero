# Copy this file to .env and fill in your values. Do not commit .env.

# Xero OAuth app: https://developer.xero.com → Your app → Client ID
XERO_CLIENT_ID=

# Google OAuth (Gmail API): Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID (Chrome app)
# Required for Gmail API sender detection. Use the same redirect URI as your extension (chrome.identity.getRedirectURL()).
GOOGLE_OAUTH_CLIENT_ID=

# GA4 (optional): Admin → Data Streams → [Web stream] → Measurement Protocol API secrets
# Leave empty to disable analytics.
GA4_MEASUREMENT_ID=
GA4_API_SECRET=
